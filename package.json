{
  "name": "pi-macro",
  "version": "0.1.0",
  "type": "module",
  "description": "Create and reuse prompt macros inside Pi.",
  "keywords": [
    "pi",
    "pi-extension",
    "macros",
    "prompts"
  ],
  "homepage": "https://github.com/bnema/pi-macro#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bnema/pi-macro.git"
  },
  "bugs": {
    "url": "https://github.com/bnema/pi-macro/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/",
    "extensions/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.78.1",
    "@types/node": "^25.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.14"
  }
}
